{
  "name": "fixmyerrorcode",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "seed": "node scripts/seed-error-codes.mjs",
    "generate": "node scripts/generate-all-error-codes.mjs",
    "generate:ai": "node scripts/generate-with-anthropic.mjs --all",
    "index": "node scripts/build-search-index.mjs",
    "patch:content": "node scripts/apply-unique-content.mjs",
    "patch:meta": "node scripts/patch-short-meta.mjs",
    "keywords:gap": "node scripts/parse-keyword-gaps.mjs",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "refresh": "node scripts/apply-unique-content.mjs && npm run clean && npm run build",
    "dev:clean": "npm run clean && next dev",
    "prebuild": "node scripts/build-search-index.mjs",
    "start": "next start",
    "kill:3000": "node scripts/kill-port.mjs 3000",
    "start:clean": "node scripts/kill-port.mjs 3000 && next start",
    "pages:deploy": "npm run build && wrangler pages deploy out --project-name=fixmyerrorcode",
    "lint": "next lint"
  },
  "dependencies": {
    "react": "^18",
    "react-dom": "^18",
    "next": "14.2.35"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "wrangler": "^4.100.0"
  }
}
